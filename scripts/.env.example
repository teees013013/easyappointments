# =============================================================================
# EasyAppointments — MySQL Connection & Backup Configuration
#
# HOW TO USE:
#   cp scripts/.env.example scripts/.env
#   # Fill in your real values in scripts/.env
#
# scripts/.env is gitignored and will never be committed.
# This file (.env.example) is the committed reference template.
#
# All scripts in this directory (provision-instance.sh, backup-databases.sh,
# setup-backup-cron.sh) will automatically source scripts/.env if it exists.
# =============================================================================

# -----------------------------------------------------------------------------
# Aiven (or other remote) MySQL — admin credentials
# Find these on your Aiven service page under "Connection Information"
# -----------------------------------------------------------------------------
MYSQL_HOST=your-service.aivencloud.com
MYSQL_PORT=12476
MYSQL_ADMIN_USER=avnadmin
MYSQL_ADMIN_PASS=AVNS_CHANGE_ME

# -----------------------------------------------------------------------------
# Backup settings (used by backup-databases.sh and setup-backup-cron.sh)
# -----------------------------------------------------------------------------
BACKUP_DIR=/opt/backups/ea-mysql
KEEP_HOURLY=24      # hourly backups retained per database  (1 day)
KEEP_WEEKLY=8       # weekly backups retained per database  (2 months)
LOG_FILE=/var/log/ea-backup.log
